# =============================================================================
# Copy this file to .env and fill in your values before running:
#   cp sample.env .env && docker compose up -d
# All variables below have sensible defaults, except the LLM API keys.
# =============================================================================

# --- LLM provider API keys (fill in the ones you use) ---
OPENAI_API_KEY="your_openai_api_key"
ANTHROPIC_API_KEY="your_anthropic_api_key"
# Zhipu AI (GLM) — OpenAI-compatible provider
ZHIPU_API_KEY="your_zhipu_api_key"
ZHIPU_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
ZHIPU_MODEL="glm-4-flash"

# --- Default LLM model used on startup ---
# One of: openai | openai-4 | anthropic | deepseek | ollama | zhipu
DEFAULT_MODEL="zhipu"

# --- Local (Ollama) LLM settings (only used if model is set to 'ollama') ---
LOCAL_LLM="gemma2:2b"
# Inside docker compose this points at the optional 'ollama' service.
# When running the app locally (without docker) use http://localhost:11434/v1
LOCAL_MODEL_URL="http://ollama:11434/v1"

# --- PostgreSQL (chat history DB) ---
DB_USERNAME="postgres"
DB_PASSWORD="password"
DB_NAME="chat_hist_db"
# Host-side port mapping (the in-container port is always 5432)
DB_PORT="5555"

# --- Redis (short-term log storage) ---
REDIS_PORT="6379"
REDIS_DB="0"

# --- FastAPI app ---
# Host-side port mapping (the in-container port is always 8000)
APP_PORT="8000"

# --- Email alerts (SMTP) ---
# Used when a log triggers an ERROR/WARN or fails to parse.
# Leave SMTP_HOST empty to disable email alerts (a warning is logged instead).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USERNAME=""
SMTP_PASSWORD=""
# Enable STARTTLS (recommended for port 587). Set "false" to disable.
SMTP_USE_TLS="true"
SMTP_FROM="ai-log-agent@example.com"
# Comma-separated recipient list, e.g. "ops@example.com, devops@example.com"
EMAIL_NOTIFY_TO=""

# --- Monitoring profile (only used with: docker compose --profile monitoring up -d) ---
# Override these if a port collides with another service on your host.
PROMETHEUS_PORT="9090"
GRAFANA_PORT="3000"
NODE_EXPORTER_PORT="9100"
CADVISOR_PORT="8080"
